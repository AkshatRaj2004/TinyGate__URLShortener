# ═══════════════════════════════════════════════════════════════════════════════
#  Tiny Gate — PRODUCTION environment variables
#
#  1. Copy this file:  cp .env.production.example .env.production
#  2. Fill in every value
#  3. NEVER commit .env.production to git
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Public domain — used to build short URLs (no trailing slash)
BASE_URL=https://yourdomain.com
DOMAIN=yourdomain.com

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=7d

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=tinygate_admin
MONGO_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MONGO_DB=tinygate
# Full URI is built in docker-compose.prod.yml — do NOT set MONGO_URI here

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://yourdomain.com
